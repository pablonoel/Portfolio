---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Header from '../../components/Header.astro'
import Hero from '../../components/Hero.astro'
import ProjectCard from '../../components/ProjectCard.astro'
---
<BaseLayout title="Photography">
  <Header />
  <Hero
    headline="Photography"
    lede="A visual diary of people, cities, and experiments with light."
  />

  <section class="section">
    <p class="section-label">Series</p>
    <div class="cards">
      <ProjectCard title="Night Walks" thumbClass="thumb-ui" meta="Street photography, 2023" />
      <ProjectCard title="Coastal Light" thumbClass="thumb-dashboard" meta="Landscape studies, 2022" />
    </div>
  </section>
</BaseLayout>
