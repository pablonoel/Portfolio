---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Header from '../../components/Header.astro'
import Hero from '../../components/Hero.astro'
import ProjectCard from '../../components/ProjectCard.astro'
---
<BaseLayout title="Featured Work">
  <Header />
  <Hero headline="Work" lede="A selection of projects from my portfolio." />

  <section class="section">
    <p class="section-label">Selected projects</p>
    <div class="cards">
      <ProjectCard
        title="Sidewalk Labs, Street Design Principles"
        href="/work/sidewalk-labs-street-design-principles/"
        thumbSrc="/assets/work/sidewalk-labs-street-design-principles/sidewalk-labs-street-design-principles_001.png"
        thumbAlt="Sidewalk Labs, Street Design Principles"
      />
      <ProjectCard
        title="New York State, Offshore Wind Training"
        href="/work/nyserda-offshore-wind/"
        thumbSrc="/assets/work/nyserda-offshore-wind/nyserda-offshore-wind_001.png"
        thumbAlt="New York State, Offshore Wind Training"
      />
      <ProjectCard
        title="Kidlinks"
        href="/work/kidlinks/"
        thumbSrc="/assets/work/kidlinks/kidlinks_001.png"
        thumbAlt="Kidlinks"
      />
      <ProjectCard
        title="Google Sidewalk Labs"
        href="/work/google-sidewalk-labs/"
        thumbSrc="/assets/work/google-sidewalk-labs/google-sidewalk-labs_001.png"
        thumbAlt="Google Sidewalk Labs"
      />
      <ProjectCard
        title="Google Mesa Dashboard"
        href="/work/google-mesa-dashboard/"
        thumbSrc="/assets/work/google-mesa-dashboard/google-mesa-dashboard_006.png"
        thumbAlt="Google Mesa Dashboard"
      />
      <ProjectCard
        title="Florida Apartment Scarcity Dashboard"
        href="/work/florida-dashboard/"
        thumbSrc="/assets/work/florida-dashboard/florida-dashboard_002.png"
        thumbAlt="Florida Apartment Scarcity Dashboard"
      />
      <ProjectCard
        title="BCI Bank"
        href="/work/bci-bank/"
        thumbSrc="/assets/work/bci-bank/bci-bank_002.jpg"
        thumbAlt="BCI Bank"
      />
      <ProjectCard
        title="Devpad"
        href="/work/devpad/"
        thumbSrc="/assets/work/devpad/devpad_003.jpg"
        thumbAlt="Devpad"
      />
      <ProjectCard
        title="CodePicnic"
        href="/work/codepicnic/"
        thumbSrc="/assets/work/codepicnic/codepicnic_005.jpg"
        thumbAlt="CodePicnic"
      />
      <ProjectCard
        title="Archdaily"
        href="/work/archdaily/"
        thumbSrc="/assets/work/archdaily/archdaily_010.jpg"
        thumbAlt="Archdaily"
      />
      <ProjectCard
        title="Find Eddie the Skater"
        href="/work/find-eddie-the-skater/"
        thumbSrc="/assets/work/find-eddie-the-skater/find-eddie-the-skater_002.png"
        thumbAlt="Find Eddie the Skater"
      />
    </div>
  </section>
</BaseLayout>
