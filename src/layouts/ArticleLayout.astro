---
import BaseLayout from './BaseLayout.astro'
import Header from '../components/Header.astro'
import Hero from '../components/Hero.astro'

interface Props {
  pageTitle: string
  headline: string
  lede?: string
  featuredSrc?: string
  featuredAlt?: string
  backHref: string
  backLabel: string
  articleClass: string
}
const { pageTitle, headline, articleClass, lede = '', featuredSrc, featuredAlt, backHref, backLabel } = Astro.props
---
<BaseLayout title={pageTitle} description={lede || undefined} image={featuredSrc || undefined}>
  <Header />
  <main class="wrapper">
    <section class="section">
      <Hero headline={headline} lede={lede} />
      <article class={`article ${articleClass}`}>
        <slot />
      </article>
      <a class="back-link" href={backHref}>{backLabel}</a>
    </section>
  </main>
</BaseLayout>
